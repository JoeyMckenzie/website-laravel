{
    "name": "joeymckenzie/website",
    "description": "My personal website and slice of the internet.",
    "license": "MIT",
    "type": "project",
    "keywords": [
        "laravel",
        "framework"
    ],
    "require": {
        "php": "^8.3",
        "calebporzio/sushi": "^2.5",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^13.0",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.14",
        "league/commonmark": "^2.7",
        "phiki/phiki": "^2.0",
        "ryangjchandler/orbit": "^1.4",
        "spatie/laravel-sitemap": "^8.1"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "carthage-software/mago": "^1.16.0",
        "driftingly/rector-laravel": "^2.2",
        "ergebnis/composer-normalize": "^2.48",
        "fakerphp/faker": "^1.24",
        "infection/infection": "^0.31.2",
        "laravel/ai": "^0.4.2",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^12.5.12",
        "rector/rector": "^2.3"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "npm run lint:check",
            "npm run fmt:check",
            "npm run types:check",
            "@fmt:check",
            "@lint",
            "@test"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "analyze": "vendor/bin/mago analyze --baseline baseline-analysis.toml",
        "fmt": "vendor/bin/mago fmt",
        "fmt:check": "vendor/bin/mago fmt --check",
        "lint": "vendor/bin/mago lint",
        "lint:fix": "vendor/bin/mago lint --fix --unsafe",
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "$schema": "https://getcomposer.org/schema.json"
}
